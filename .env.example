# ---------------------------------------------------------------------------
# Copy this file to .env and fill in values. docker-compose reads it for the
# backend service. All values have safe defaults except secrets you may add.
# ---------------------------------------------------------------------------

# JWT signing secret — change this to a long random string.
JWT_SECRET=please-change-this-to-a-long-random-string

# --- Google Gemini ---
# Leave GEMINI_API_KEY blank to run with the built-in stub analyzer (the app
# still works end-to-end; AI fields are placeholders). Set it to enable real
# image analysis and natural-language search parsing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Object storage (Cloudflare R2 or AWS S3) ---
# Leave these blank to store uploaded images on the backend's local disk
# (served from /uploads). Fill them in to use a real bucket.
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Public URL prefix that serves the bucket (e.g. an R2 public bucket URL).
S3_PUBLIC_BASE_URL=
